{
  "name": "3dgen-demoroom-web",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@11.7.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/require-manifest.mjs && vite",
    "build": "node scripts/validate-wrangler-config.mjs && node scripts/require-manifest.mjs --reject-partial && tsc -p tsconfig.json && vite build && node scripts/copy-references.mjs",
    "test": "node --test scripts/*.test.mjs",
    "test:config": "node --test scripts/validate-wrangler-config.test.mjs",
    "test:manifest": "node --test scripts/require-manifest.test.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "three": "^0.185.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^5.0.0",
    "jsonc-parser": "^3.3.1",
    "tailwindcss": "^4.1.0",
    "typescript": "~5.9.0",
    "vite": "^8.1.0",
    "wrangler": "^4.107.0"
  }
}
