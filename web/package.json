{
  "name": "3dgen-demoroom-web",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@11.7.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/require-manifest.mjs && vite",
    "build": "node scripts/require-manifest.mjs --reject-partial && tsc -p tsconfig.json && vite build && node scripts/copy-references.mjs",
    "test": "vitest run",
    "test:manifest": "node --test scripts/require-manifest.test.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "three": "^0.185.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.1.0",
    "typescript": "~5.9.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.107.0"
  }
}
