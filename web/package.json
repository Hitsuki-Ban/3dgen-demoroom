{
  "name": "3dgen-demoroom-web",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@11.7.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/build-thumbnails.mjs && node scripts/require-manifest.mjs && vite",
    "build": "node scripts/validate-wrangler-config.mjs && node scripts/build-thumbnails.mjs && node scripts/require-manifest.mjs --reject-partial && tsc -p tsconfig.json && vite build && node scripts/copy-references.mjs",
    "test": "vitest run && node --test scripts/*.test.mjs",
    "test:config": "node --test scripts/validate-wrangler-config.test.mjs",
    "test:manifest": "node --test scripts/require-manifest.test.mjs",
    "test:worker": "wrangler types src/worker-configuration.d.ts --include-runtime=false --check && tsc -p test/tsconfig.json && vitest run --config vitest.worker.config.ts",
    "preview": "vite preview",
    "thumbnail:install-browser": "playwright install chromium",
    "thumbnail:render": "node scripts/thumbnail-renderer.mjs",
    "thumbnail:generate": "node scripts/generate-thumbnails.mjs",
    "thumbnail:check": "node scripts/generate-thumbnails.mjs --check",
    "test:thumbnails": "node --test scripts/generate-thumbnails.test.mjs && node scripts/thumbnail-render-smoke.mjs"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "three": "0.185.1"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "3.1079.0",
    "@cloudflare/vitest-pool-workers": "0.18.4",
    "@cloudflare/workers-types": "5.20260708.1",
    "@tailwindcss/vite": "^4.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^29.1.1",
    "jsonc-parser": "^3.3.1",
    "playwright": "1.61.1",
    "sharp": "0.35.3",
    "tailwindcss": "^4.1.0",
    "typescript": "~5.9.0",
    "vite": "8.1.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
